# CariPropShop Environment Configuration
# Copy this file to .env and update with your values

# Database Configuration
MYSQL_ROOT_PASSWORD=CariPropShopRoot2026!
MYSQL_DATABASE=caripropshop
MYSQL_USER=cpuser
MYSQL_PASSWORD=CpPass123!

# WordPress Configuration
TABLE_PREFIX=cps_
WP_TITLE=CariPropShop
WP_URL=https://www.caripropshop.com
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=CariPropShop2026!
WP_ADMIN_EMAIL=admin@caripropshop.com

# PHP Configuration
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=300
PHP_UPLOAD_MAX_FILESIZE=64M
PHP_POST_MAX_SIZE=64M

# Development Mode
NODE_ENV=development
WP_DEBUG=1
WP_DEBUG_LOG=1
WP_DEBUG_DISPLAY=0

# API Keys (to be configured)
GOOGLE_MAPS_API_KEY=
RANK_MATH_API_KEY=

# Email Configuration
WP_MAIL_HOST=smtp.example.com
WP_MAIL_PORT=587
WP_MAIL_USERNAME=
WP_MAIL_PASSWORD=
WP_MAIL_FROM=noreply@caripropshop.com
WP_MAIL_FROM_NAME=CariPropShop
